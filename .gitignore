# 1. THE SHIELD: Ignore everything in the project by default
/*

# 2. ROOT FILES: Essential config files
!/.gitignore
!/package.json
!/package-lock.json
!/next.config.ts
!/next.config.js
!/tsconfig.json
!/postcss.config.mjs
!/eslint.config.mjs
!/README.md

!/*.json
!/*.js
!/*.ts
!/*.mjs
!/*.cjs
!/.gitignore
!/README.md

# 3. ROOT COMPONENTS ONLY: (The slash guarantees pro-scout-ui is ignored)
!/app/components/
!/app/components/**

# 4. LANE 1 ENGINE: Un-hide the app folder, but block everything inside it first
!/app/
/app/*

# Un-hide only specific sub-directories inside /app
!/app/api/
!/app/club-seasons/
!/app/generate/
!/app/search/
!/app/seasons/

# Essential Next.js UI files for the root
!/app/layout.tsx
!/app/page.tsx
!/app/globals.css
# PUBLIC ASSETS (Logos, images, etc.)
!/public/
!/public/**

# 5. ULTIMATE SAFETY NET: Always ignore these, even if whitelisted above
node_modules/
.next/
out/
build/
*.db
ProScout_Scraper/
.env*
.DS_Store